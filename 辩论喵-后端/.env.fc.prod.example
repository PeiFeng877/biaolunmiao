APP_NAME=辩论喵后端
APP_ENV=prod
API_V1_PREFIX=/api/v1
SECRET_KEY=replace-with-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_MINUTES=43200
DATABASE_URL=postgresql+psycopg2://<db_user>:<db_password>@<rds_private_host>:5432/bianlunmiao
RUN_MIGRATIONS_ON_BOOT=true
ENABLE_DEBUG_TOKEN=false
APPLE_ALLOWED_AUDIENCES=com.wenwan.BianLunMiao
APPLE_JWKS_URL=https://appleid.apple.com/auth/keys
APPLE_JWKS_FALLBACK_JSON=
ALLOW_INSECURE_APPLE_TOKEN_VALIDATION=false
SMS_AUTH_PROVIDER=aliyun
ALIYUN_SMS_AUTH_ACCESS_KEY_ID=replace-with-aliyun-ak
ALIYUN_SMS_AUTH_ACCESS_KEY_SECRET=replace-with-aliyun-sk
ALIYUN_SMS_AUTH_SIGN_NAME=replace-with-gifted-or-configured-sign
ALIYUN_SMS_AUTH_TEMPLATE_CODE=replace-with-gifted-or-configured-template
ALIYUN_SMS_AUTH_SCHEME_NAME=
ALIYUN_SMS_AUTH_CODE_TTL_SECONDS=300
ALIYUN_SMS_AUTH_RESEND_INTERVAL_SECONDS=60
ALIYUN_SMS_AUTH_MAX_ATTEMPTS=5
MEDIA_BACKEND=oss
LOCAL_MEDIA_ROOT=.data/uploads
OSS_BUCKET=bianlunmiao-assets-1917380129637610
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=replace-with-sts-ak
OSS_ACCESS_KEY_SECRET=replace-with-sts-sk
OSS_SECURITY_TOKEN=replace-with-sts-token
OSS_PUBLIC_BASE_URL=https://bianlunmiao-assets-1917380129637610.oss-cn-hangzhou.aliyuncs.com
OSS_ENV_PREFIX=prod
