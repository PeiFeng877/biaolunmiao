APP_NAME=辩论喵后端
APP_ENV=local
API_V1_PREFIX=/api/v1
SECRET_KEY=change-this-in-real-env
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_MINUTES=43200
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/bianlunmiao
ENABLE_DEBUG_TOKEN=true
APPLE_ALLOWED_AUDIENCES=com.wenwan.BianLunMiao
APPLE_JWKS_URL=https://appleid.apple.com/auth/keys
APPLE_JWKS_FALLBACK_JSON=
ALLOW_INSECURE_APPLE_TOKEN_VALIDATION=true
SMS_AUTH_PROVIDER=mock
ALIYUN_SMS_AUTH_ACCESS_KEY_ID=
ALIYUN_SMS_AUTH_ACCESS_KEY_SECRET=
ALIYUN_SMS_AUTH_SIGN_NAME=
ALIYUN_SMS_AUTH_TEMPLATE_CODE=
ALIYUN_SMS_AUTH_SCHEME_NAME=
ALIYUN_SMS_AUTH_CODE_TTL_SECONDS=300
ALIYUN_SMS_AUTH_RESEND_INTERVAL_SECONDS=60
ALIYUN_SMS_AUTH_MAX_ATTEMPTS=5
MEDIA_BACKEND=local
PUBLIC_BASE_URL=
LOCAL_MEDIA_ROOT=.data/uploads
OSS_BUCKET=
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_SECURITY_TOKEN=
OSS_PUBLIC_BASE_URL=
OSS_ENV_PREFIX=prod
